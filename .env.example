# Git provider: "github" or "gitlab"
GIT_PROVIDER=github

# Git platform credentials (generic names)
WEBHOOK_SECRET=your_webhook_secret_here
API_TOKEN=your_token_here
GIT_REPO=owner/repo
BOT_USERNAME=your-bot-username

# Self-managed instance base URL (optional, leave empty for github.com / gitlab.com)
# GIT_BASE_URL=https://gitlab.company.com

# Legacy GitHub-specific names (also accepted for backward compatibility)
# GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
# GITHUB_TOKEN=ghp_your_token_here
# GITHUB_REPO=owner/repo
# BOT_GITHUB_USERNAME=your-bot-github-username

# Hermes gateway (run separately via `hermes gateway start`)
HERMES_GATEWAY_URL=http://127.0.0.1:8642

# Allow bot to respond to its own opened issues (for single-user testing)
# ALLOW_SELF_TRIGGER=false

# Legacy Telegram settings (no longer used directly — Hermes handles Telegram)
# TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# TELEGRAM_CHAT_ID=your_chat_id

# tmux (kept for observability — `tmux attach -t agent-flow`)
TMUX_SESSION_NAME=agent-flow
REPO_LOCAL_PATH=/path/to/your/target/repo

# Timing
MONITOR_POLL_SECONDS=30
IDLE_TIMEOUT_SECONDS=300

# Pipeline limits
MAX_REVIEW_CYCLES=3
MAX_DECOMPOSITION_DEPTH=1

# Storage
SQLITE_DB_PATH=/tmp/agent-flow/state.db
PROMPT_DIR=/tmp/agent-flow/prompts
WORKTREE_DIR=/tmp/agent-flow/worktrees

# Deduplication TTL (hours)
DEDUP_TTL_HOURS=24
